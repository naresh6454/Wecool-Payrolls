# Copy this file to .env and fill in your values

# SQLite (local dev) or your production DB URL
DATABASE_URL="file:./dev.db"

# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET="change-me-to-a-strong-random-secret"

NEXTAUTH_URL="http://localhost:3000"

# Resend email service — get your key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Wecool Payroll <hr@yourdomain.com>"
