# Copy this file to .env and fill in your values

# Neon PostgreSQL (production) — get from https://neon.tech
# Format: postgresql://user:password@ep-xxx.ap-south-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET="change-me-to-a-strong-random-secret"

NEXTAUTH_URL="https://your-app.vercel.app"

# Resend email service — get your key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Wecool Payroll <hr@yourdomain.com>"
